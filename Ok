-- HD Admin setup
local function giveHDAdmin()
    if not _G.HDAdminLoaded then
        _G.HDAdminLoaded = true
        local HDAdmin = loadstring(game:HttpGet("https://raw.githubusercontent.com/EdgeIY/infiniteyield/master/source"))()
        HDAdmin:Init()
    end
end

-- Fly function
local flying = false
local flySpeed = 50
local flyBodyGyro, flyBodyVelocity

local function startFly()
    if flying then return end
    flying = true
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    flyBodyGyro = Instance.new("BodyGyro", hrp)
    flyBodyGyro.P = 9e4
    flyBodyGyro.MaxTorque = Vector3.new(9e4, 9e4, 9e4)
    flyBodyGyro.CFrame = hrp.CFrame

    flyBodyVelocity = Instance.new("BodyVelocity", hrp)
    flyBodyVelocity.Velocity = Vector3.new(0,0,0)
    flyBodyVelocity.MaxForce = Vector3.new(9e4, 9e4, 9e4)

    local userInputService = game:GetService("UserInputService")

    spawn(function()
        while flying do
            wait()
            local moveDirection = Vector3.new(0,0,0)
            if userInputService:IsKeyDown(Enum.KeyCode.W) then
                moveDirection = moveDirection + workspace.CurrentCamera.CFrame.LookVector
            end
            if userInputService:IsKeyDown(Enum.KeyCode.S) then
                moveDirection = moveDirection - workspace.CurrentCamera.CFrame.LookVector
            end
            if userInputService:IsKeyDown(Enum.KeyCode.A) then
                moveDirection = moveDirection - workspace.CurrentCamera.CFrame.RightVector
            end
            if userInputService:IsKeyDown(Enum.KeyCode.D) then
                moveDirection = moveDirection + workspace.CurrentCamera.CFrame.RightVector
            end
            flyBodyVelocity.Velocity = moveDirection.Unit * flySpeed + Vector3.new(0,0,0)
            flyBodyGyro.CFrame = workspace.CurrentCamera.CFrame
        end
        if flyBodyGyro then flyBodyGyro:Destroy() end
        if flyBodyVelocity then flyBodyVelocity:Destroy() end
    end)
end

local function stopFly()
    flying = false
end

-- Infinity Jump
local UserInputService = game:GetService("UserInputService")
local canInfinityJump = false

UserInputService.JumpRequest:Connect(function()
    if canInfinityJump then
        if humanoid:GetState() ~= Enum.HumanoidStateType.Freefall then
            humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
        end
    end
end)

-- Speed
local speedValue = 16
local speedEnabled = false

local function setSpeed(val)
    if humanoid then
        humanoid.WalkSpeed = val
    end
end

-- Buttons

Window:CreateButton({
    Name = "Fly (Toggle)",
    Callback = function()
        if flying then
            stopFly()
        else
            startFly()
        end
    end
})

Window:CreateToggle({
    Name = "Infinity Jump",
    CurrentValue = false,
    Flag = "InfinityJumpToggle",
    Callback = function(value)
        canInfinityJump = value
    end
})

Window:CreateSlider({
    Name = "Speed",
    Min = 16,
    Max = 250,
    Default = 16,
    Color = Color3.fromRGB(255,255,255),
    Increment = 1,
    ValueName = "WalkSpeed",
    Callback = function(value)
        speedValue = value
        if speedEnabled then
            setSpeed(speedValue)
        end
    end
})

Window:CreateToggle({
    Name = "Speed Enable",
    CurrentValue = false,
    Flag = "SpeedToggle",
    Callback = function(value)
        speedEnabled = value
        if speedEnabled then
            setSpeed(speedValue)
        else
            setSpeed(16)
        end
    end
})

Window:CreateButton({
    Name = "Give HD Admin",
    Callback = function()
        giveHDAdmin()
    end
})
